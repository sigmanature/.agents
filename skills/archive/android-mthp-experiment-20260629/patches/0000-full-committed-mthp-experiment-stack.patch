+
+static int __test_multi_pages_comp(struct zram *zram, u32 index)
+{
+	int i, count = 0;
+	u32 head = zram_multi_pages_head_index(index);
+
+	for (i = 0; i < ZCOMP_MULTI_PAGES_NR; i++) {
+		if (zram_test_flag(zram, head + i, ZRAM_COMP_MULTI_PAGES))
+			count++;
+	}
+
+	return count;
+}
+
+static bool want_multi_pages_comp(struct zram *zram, struct bio *bio)
+{
+	u32 index = bio->bi_iter.bi_sector >> SECTORS_PER_PAGE_SHIFT;
+	bool ret;
+
+	if (bio->bi_io_vec->bv_len >= ZCOMP_MULTI_PAGES_SIZE)
+		return true;
+
+	zram_slot_lock(zram, index);
+	ret = __test_multi_pages_comp(zram, index);
+	zram_slot_unlock(zram, index);
+
+	return ret;
+}
+
+static bool test_multi_pages_comp(struct zram *zram, struct bio *bio)
+{
+	u32 index = bio->bi_iter.bi_sector >> SECTORS_PER_PAGE_SHIFT;
+	bool ret;
+
+	zram_slot_lock(zram, index);
+	ret = __test_multi_pages_comp(zram, index);
+	zram_slot_unlock(zram, index);
+
+	return ret;
+}
+
+static bool is_multi_pages_partial_io(struct bio_vec *bvec)
+{
+	return bvec->bv_len != ZCOMP_MULTI_PAGES_SIZE;
+}
+
+static int zram_bvec_read_multi_pages_partial(struct zram *zram,
+					      struct bio_vec *bvec,
+					      u32 index, int offset,
+					      struct bio *bio)
+{
+	struct page *page;
+	void *dst;
+	int ret;
+
+	page = alloc_pages(GFP_NOIO | __GFP_COMP, ZCOMP_MULTI_PAGES_ORDER);
+	if (!page)
+		return -ENOMEM;
+
+	ret = zram_read_page_size(zram, page, index, bio, ZCOMP_MULTI_PAGES_SIZE);
+	if (!ret) {
+		dst = kmap_local_page(page);
+		memcpy_to_bvec(bvec, dst + offset);
+		kunmap_local(dst);
+		atomic64_inc(&zram->stats.zram_bio_read_multi_pages_partial_count);
+	}
+
+	__free_pages(page, ZCOMP_MULTI_PAGES_ORDER);
+	return ret;
+}
+
+static int zram_bvec_read_multi_pages(struct zram *zram, struct bio_vec *bvec,
+				      u32 index, int offset, struct bio *bio)
+{
+	if (is_multi_pages_partial_io(bvec))
+		return zram_bvec_read_multi_pages_partial(zram, bvec, index,
+							  offset, bio);
+
+	return zram_read_page_size(zram, bvec->bv_page, index, bio,
+				   ZCOMP_MULTI_PAGES_SIZE);
+}
+
+static int zram_bvec_write_multi_pages_partial(struct zram *zram,
+					       struct bio_vec *bvec,
+					       u32 index, int offset,
+					       struct bio *bio)
+{
+	struct page *page;
+	void *src, *dst;
+	int ret;
+
+	page = alloc_pages(GFP_NOIO | __GFP_COMP, ZCOMP_MULTI_PAGES_ORDER);
+	if (!page)
+		return -ENOMEM;
+
+	ret = zram_read_page_size(zram, page, index, bio, ZCOMP_MULTI_PAGES_SIZE);
+	if (!ret) {
+		src = kmap_local_page(bvec->bv_page);
+		dst = kmap_local_page(page);
+		memcpy(dst + offset, src + bvec->bv_offset, bvec->bv_len);
+		kunmap_local(dst);
+		kunmap_local(src);
+
+		atomic64_inc(&zram->stats.zram_bio_write_multi_pages_partial_count);
+		ret = zram_write_page(zram, page, index);
+	}
+
+	__free_pages(page, ZCOMP_MULTI_PAGES_ORDER);
+	return ret;
