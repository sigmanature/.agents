+static bool f2fs_large_folio_subpage_is_all_zero(struct folio *folio,
+						  pgoff_t sub_idx)
+{
+	void *addr;
+	bool all_zero;
+
+	addr = kmap_local_folio(folio, sub_idx * PAGE_SIZE);
+	all_zero = !memchr_inv(addr, 0, PAGE_SIZE);
+	kunmap_local(addr);
+	return all_zero;
