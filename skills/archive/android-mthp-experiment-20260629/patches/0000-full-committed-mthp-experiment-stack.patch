+			snprintf(combined, sizeof(combined), "%s%s",
+				 anon_name->name, debug);
+			combined_name = anon_vma_name_alloc(combined);
+			if (combined_name) {
+				vma->anon_name = combined_name;
+				anon_vma_name_put(orig_name);
+				return 0;
+			}
+		}
+	}
+
 	vma->anon_name = anon_vma_name_reuse(anon_name);
 	anon_vma_name_put(orig_name);
 
