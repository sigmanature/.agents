 DEFINE_PER_CPU(unsigned long, deferred_split_reason_counts[DSR_NR]);
+static DEFINE_PER_CPU(unsigned long, deferred_shrinker_split_count);
+static DEFINE_PER_CPU(unsigned long, deferred_shrinker_nosplit_return_count);
 
 /*
  * By default, transparent hugepage support is disabled in order to avoid
@@ -74,6 +76,7 @@ unsigned long transparent_hugepage_flags __read_mostly =
 	(1<<TRANSPARENT_HUGEPAGE_USE_ZERO_PAGE_FLAG);
 
 static struct shrinker *deferred_split_shrinker;
+static bool deferred_split_shrinker_nosplit;
 static unsigned long deferred_split_count(struct shrinker *shrink,
 					  struct shrink_control *sc);
 static unsigned long deferred_split_scan(struct shrinker *shrink,
@@ -4166,6 +4169,11 @@ static unsigned long deferred_split_scan(struct shrinker *shrink,
 		ds_queue = &sc->memcg->deferred_split_queue;
 #endif
 
+	if (READ_ONCE(deferred_split_shrinker_nosplit)) {
+		this_cpu_inc(deferred_shrinker_nosplit_return_count);
+		return 0;
+	}
+
 	spin_lock_irqsave(&ds_queue->split_queue_lock, flags);
 	/* Take pin on all head pages to avoid freeing them under us */
 	list_for_each_entry_safe(folio, next, &ds_queue->split_queue,
@@ -4210,6 +4218,7 @@ static unsigned long deferred_split_scan(struct shrinker *shrink,
 			did_split = true;
 			if (underused)
 				count_vm_event(THP_UNDERUSED_SPLIT_PAGE);
+			this_cpu_inc(deferred_shrinker_split_count);
 			split++;
 		}
 		folio_unlock(folio);
@@ -4615,6 +4624,37 @@ static const struct file_operations deferred_split_reason_fops = {
 	.release = single_release,
 };
 
+static int deferred_split_experiment_show(struct seq_file *m, void *v)
+{
+	unsigned long split = 0, nosplit_return = 0;
+	int cpu;
+
+	for_each_possible_cpu(cpu) {
+		split += per_cpu(deferred_shrinker_split_count, cpu);
+		nosplit_return += per_cpu(deferred_shrinker_nosplit_return_count, cpu);
+	}
+
+	seq_printf(m, "deferred_shrinker_nosplit_enabled %u\n",
+		   READ_ONCE(deferred_split_shrinker_nosplit) ? 1 : 0);
+	seq_printf(m, "deferred_shrinker_split %lu\n", split);
+	seq_printf(m, "deferred_shrinker_nosplit_return %lu\n",
+		   nosplit_return);
+	return 0;
+}
+
+static int deferred_split_experiment_open(struct inode *inode, struct file *file)
+{
+	return single_open(file, deferred_split_experiment_show, NULL);
+}
+
+static const struct file_operations deferred_split_experiment_fops = {
+	.owner	 = THIS_MODULE,
+	.open	 = deferred_split_experiment_open,
+	.read	 = seq_read,
+	.llseek	 = seq_lseek,
+	.release = single_release,
+};
+
 static const struct file_operations split_huge_pages_fops = {
 	.owner	 = THIS_MODULE,
 	.write	 = split_huge_pages_write,
@@ -4626,6 +4666,10 @@ static int __init split_huge_pages_debugfs(void)
 			    &split_huge_pages_fops);
 	debugfs_create_file("deferred_split_reasons", 0400, NULL, NULL,
 			    &deferred_split_reason_fops);
+	debugfs_create_bool("deferred_split_shrinker_nosplit", 0600, NULL,
+			    &deferred_split_shrinker_nosplit);
+	debugfs_create_file("mthp_experiment_counters", 0400, NULL, NULL,
+			    &deferred_split_experiment_fops);
 	return 0;
 }
 late_initcall(split_huge_pages_debugfs);
