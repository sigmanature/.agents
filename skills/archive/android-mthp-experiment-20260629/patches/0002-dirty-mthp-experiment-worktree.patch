+static enum mthp_exp_fallback_subreason
+count_mthp_suitable_order2_reason(struct vm_area_struct *vma,
+				  unsigned long addr, bool swpin)
+{
+	unsigned long size = MTHP_EXP_ORDER2_SIZE;
+	unsigned long haddr = ALIGN_DOWN(addr, size);
+
+	if (!vma_is_anonymous(vma) &&
+	    !IS_ALIGNED((vma->vm_start >> PAGE_SHIFT) - vma->vm_pgoff,
+			size >> PAGE_SHIFT)) {
+		if (swpin)
+			mthp_exp_inc(MTHP_EXP_SWPIN_SUITABLE_FILE_PGOFF_MISALIGNED_ORDER2);
+		return MTHP_EXP_SUB_ORDER2_FILE_PGOFF_MISALIGNED;
+	}
+
+	if (vma->vm_end - vma->vm_start < size) {
+		mthp_exp_inc(swpin ? MTHP_EXP_SWPIN_SUITABLE_ORDER2_VMA_TOO_SMALL :
+			MTHP_EXP_ANON_SUITABLE_ORDER2_VMA_TOO_SMALL);
+		return MTHP_EXP_SUB_ORDER2_VMA_TOO_SMALL;
+	}
+
+	if (haddr < vma->vm_start) {
+		mthp_exp_inc(swpin ? MTHP_EXP_SWPIN_SUITABLE_ORDER2_LEFT_BOUNDARY :
+			MTHP_EXP_ANON_SUITABLE_ORDER2_LEFT_BOUNDARY);
+		return MTHP_EXP_SUB_ORDER2_LEFT_BOUNDARY;
+	}
+
+	if (haddr + size > vma->vm_end) {
+		mthp_exp_inc(swpin ? MTHP_EXP_SWPIN_SUITABLE_ORDER2_RIGHT_BOUNDARY :
+			MTHP_EXP_ANON_SUITABLE_ORDER2_RIGHT_BOUNDARY);
+		return MTHP_EXP_SUB_ORDER2_RIGHT_BOUNDARY;
+	}
+
+	mthp_exp_inc(swpin ? MTHP_EXP_SWPIN_SUITABLE_UNKNOWN :
+		MTHP_EXP_ANON_SUITABLE_UNKNOWN);
+	return MTHP_EXP_SUB_UNKNOWN;
+}
+
+static enum mthp_exp_fallback_subreason
+count_swpin_swap_suitable_order2_reason(unsigned long swp_offset,
+					unsigned long addr,
+					unsigned long orders)
+{
+	unsigned long nr = 1UL << MTHP_EXP_ORDER2;
+	unsigned long addr_mod, swp_mod;
+
+	if ((orders & MTHP_EXP_ORDER2_MASK) &&
+	    (addr >> PAGE_SHIFT) % nr != swp_offset % nr) {
+		addr_mod = (addr >> PAGE_SHIFT) & 3;
+		swp_mod = swp_offset & 3;
+
+		mthp_exp_inc(MTHP_EXP_SWPIN_SWAP_SUITABLE_ORDER2_OFFSET_MISMATCH);
+		mthp_exp_inc(MTHP_EXP_SWPIN_OFFSET_MISMATCH_ADDR0_SWP0 +
+			     addr_mod * 4 + swp_mod);
+		return MTHP_EXP_SUB_ORDER2_SWAP_OFFSET_MISMATCH;
+	}
+
+	return MTHP_EXP_SUB_UNKNOWN;
+}
