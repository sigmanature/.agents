+static unsigned long mthp_exp_supported_orders(struct vm_area_struct *vma)
+{
+	if (vma_is_anonymous(vma))
+		return THP_ORDERS_ALL_ANON;
+	if (vma_is_special_huge(vma))
+		return THP_ORDERS_ALL_SPECIAL;
+	return THP_ORDERS_ALL_FILE_DEFAULT;
+}
+
+static unsigned long mthp_exp_effective_anon_orders(vm_flags_t vm_flags)
+{
+	unsigned long mask = READ_ONCE(huge_anon_orders_always);
+
+	if (vm_flags & VM_HUGEPAGE)
+		mask |= READ_ONCE(huge_anon_orders_madvise);
+	if (hugepage_global_always() ||
+	    ((vm_flags & VM_HUGEPAGE) && hugepage_global_enabled()))
+		mask |= READ_ONCE(huge_anon_orders_inherit);
+	return mask;
+}
+
+static void mthp_exp_fill_order_masks(struct vm_area_struct *vma,
+				      unsigned long requested_orders,
+				      unsigned long allowable_orders,
+				      unsigned long suitable_orders,
+				      struct mthp_exp_trace_info *masks)
+{
+	masks->requested = requested_orders;
+	masks->supported = mthp_exp_supported_orders(vma);
+	masks->always = READ_ONCE(huge_anon_orders_always);
+	masks->madvise = READ_ONCE(huge_anon_orders_madvise);
+	masks->inherit = READ_ONCE(huge_anon_orders_inherit);
+	masks->effective = vma_is_anonymous(vma) ?
+		mthp_exp_effective_anon_orders(vma->vm_flags) : 0;
+	masks->allowable = allowable_orders;
+	masks->suitable = suitable_orders;
+	masks->swp_offset = 0;
+}
+
+static enum mthp_exp_fallback_subreason
+count_mthp_allowable_order2_reason(struct vm_area_struct *vma,
+				   unsigned long requested_orders, bool swpin)
+{
+	unsigned long supported = mthp_exp_supported_orders(vma);
+	unsigned long always = READ_ONCE(huge_anon_orders_always);
+	unsigned long madvise = READ_ONCE(huge_anon_orders_madvise);
+	unsigned long inherit = READ_ONCE(huge_anon_orders_inherit);
+	unsigned long effective = vma_is_anonymous(vma) ?
+		mthp_exp_effective_anon_orders(vma->vm_flags) : 0;
+	enum mthp_exp_counter counter;
+
+	if (!(requested_orders & MTHP_EXP_ORDER2_MASK)) {
+		counter = swpin ? MTHP_EXP_SWPIN_ALLOWABLE_REQUESTED_LACKS_ORDER2 :
+			MTHP_EXP_ANON_ALLOWABLE_REQUESTED_LACKS_ORDER2;
+		mthp_exp_inc(counter);
+		return MTHP_EXP_SUB_REQUESTED_LACKS_ORDER2;
+	}
+
+	if (!(supported & MTHP_EXP_ORDER2_MASK)) {
+		counter = swpin ? MTHP_EXP_SWPIN_ALLOWABLE_SUPPORTED_LACKS_ORDER2 :
+			MTHP_EXP_ANON_ALLOWABLE_SUPPORTED_LACKS_ORDER2;
+		mthp_exp_inc(counter);
+		return MTHP_EXP_SUB_SUPPORTED_LACKS_ORDER2;
+	}
+
+	if (vma_is_anonymous(vma) && !(effective & MTHP_EXP_ORDER2_MASK)) {
+		if (!(always & MTHP_EXP_ORDER2_MASK) &&
+		    (madvise & MTHP_EXP_ORDER2_MASK) &&
+		    !(vma->vm_flags & VM_HUGEPAGE)) {
+			counter = swpin ?
+				MTHP_EXP_SWPIN_ALLOWABLE_ORDER2_ONLY_IN_MADVISE_BUT_VMA_NOT_HUGE :
+				MTHP_EXP_ANON_ALLOWABLE_ORDER2_ONLY_IN_MADVISE_BUT_VMA_NOT_HUGE;
+			mthp_exp_inc(counter);
+			return MTHP_EXP_SUB_ORDER2_ONLY_IN_MADVISE_BUT_VMA_NOT_HUGE;
+		}
+		if (!(always & MTHP_EXP_ORDER2_MASK) &&
+		    (inherit & MTHP_EXP_ORDER2_MASK) &&
+		    !(hugepage_global_always() ||
+		      ((vma->vm_flags & VM_HUGEPAGE) && hugepage_global_enabled()))) {
+			counter = swpin ?
+				MTHP_EXP_SWPIN_ALLOWABLE_ORDER2_ONLY_IN_INHERIT_BUT_GLOBAL_NOT_ALLOWING :
+				MTHP_EXP_ANON_ALLOWABLE_ORDER2_ONLY_IN_INHERIT_BUT_GLOBAL_NOT_ALLOWING;
+			mthp_exp_inc(counter);
+			return MTHP_EXP_SUB_ORDER2_ONLY_IN_INHERIT_BUT_GLOBAL_NOT_ALLOWING;
+		}
+		if (!(always & MTHP_EXP_ORDER2_MASK)) {
+			counter = swpin ? MTHP_EXP_SWPIN_ALLOWABLE_ORDER2_NOT_IN_ALWAYS :
+				MTHP_EXP_ANON_ALLOWABLE_ORDER2_NOT_IN_ALWAYS;
+			mthp_exp_inc(counter);
+			return MTHP_EXP_SUB_ORDER2_NOT_IN_ALWAYS;
+		}
+		counter = swpin ? MTHP_EXP_SWPIN_ALLOWABLE_EFFECTIVE_MASK_LACKS_ORDER2 :
+			MTHP_EXP_ANON_ALLOWABLE_EFFECTIVE_MASK_LACKS_ORDER2;
+		mthp_exp_inc(counter);
+		return MTHP_EXP_SUB_EFFECTIVE_MASK_LACKS_ORDER2;
+	}
+
+	if (vma_is_anonymous(vma) &&
+	    !(requested_orders & supported & effective)) {
+		counter = swpin ? MTHP_EXP_SWPIN_ALLOWABLE_EFFECTIVE_MASK_NO_INTERSECTION :
+			MTHP_EXP_ANON_ALLOWABLE_EFFECTIVE_MASK_NO_INTERSECTION;
+		mthp_exp_inc(counter);
+		return MTHP_EXP_SUB_EFFECTIVE_MASK_NO_INTERSECTION;
+	}
+
+	if (!vma->vm_mm || thp_disabled_by_hw() ||
+	    vma_thp_disabled(vma, vma->vm_flags, false)) {
+		counter = swpin ? MTHP_EXP_SWPIN_ALLOWABLE_UNEXPECTED_DISABLED :
+			MTHP_EXP_ANON_ALLOWABLE_UNEXPECTED_DISABLED;
+		mthp_exp_inc(counter);
+		return MTHP_EXP_SUB_UNEXPECTED_DISABLED;
+	}
+
+	if (vma_is_temporary_stack(vma)) {
+		counter = swpin ? MTHP_EXP_SWPIN_ALLOWABLE_TEMPORARY_STACK :
+			MTHP_EXP_ANON_ALLOWABLE_TEMPORARY_STACK;
+		mthp_exp_inc(counter);
+		return MTHP_EXP_SUB_TEMPORARY_STACK;
+	}
+
+	if (!vma_is_anonymous(vma)) {
+		if (!hugepage_global_enabled() ||
+		    (!(vma->vm_flags & VM_HUGEPAGE) && !hugepage_global_always())) {
+			if (swpin)
+				mthp_exp_inc(MTHP_EXP_SWPIN_ALLOWABLE_NONANON_GLOBAL_DISABLED);
+			return MTHP_EXP_SUB_NONANON_GLOBAL_DISABLED;
+		}
+
+		if (!vma->vm_ops || !vma->vm_ops->huge_fault) {
+			if (swpin)
+				mthp_exp_inc(MTHP_EXP_SWPIN_ALLOWABLE_NONANON_NO_HUGE_FAULT);
+			return MTHP_EXP_SUB_NONANON_NO_HUGE_FAULT;
+		}
+	}
+
+	counter = swpin ? MTHP_EXP_SWPIN_ALLOWABLE_UNKNOWN :
+		MTHP_EXP_ANON_ALLOWABLE_UNKNOWN;
+	mthp_exp_inc(counter);
+	return MTHP_EXP_SUB_UNKNOWN;
+}
